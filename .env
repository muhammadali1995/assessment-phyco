# ============================================
# Assessment Generation Platform — Environment
# ============================================

# --- App ---
NODE_ENV=development
APP_PORT=3000
APP_DOMAIN=http://localhost:3000
LOG_LEVEL=debug

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=assessment_platform
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# --- FluentCRM ---
FLUENTCRM_API_URL=https://your-wordpress-site.com/wp-json/fluent-crm/v2
FLUENTCRM_API_KEY=your_fluentcrm_api_key
FLUENTCRM_API_SECRET=your_fluentcrm_api_secret

# --- Webhook Auth (Fluent Forms → API) ---
WEBHOOK_BEARER_TOKEN=generate_a_64_char_random_token_here

# --- Payment Provider (Stripe example) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- DigitalOcean Spaces (S3-compatible) ---
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_BUCKET=assessment-reports
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# --- Admin Auth ---
JWT_SECRET=generate_a_64_char_random_secret_here
JWT_EXPIRY=24h
ADMIN_DEFAULT_EMAIL=admin@saferelate.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_ON_FIRST_LOGIN

# --- Report Settings ---
REPORT_URL_EXPIRY_DAYS=7
FULL_REPORT_PRICE=5.00

# --- BullMQ ---
BULLMQ_MAX_RETRIES=3
BULLMQ_BACKOFF_DELAY=5000
BULLMQ_CONCURRENCY=3
